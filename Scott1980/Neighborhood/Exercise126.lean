import Scott1980.Neighborhood.Basic
import Mathlib.RingTheory.Ideal.Span
import Mathlib.Tactic

/-!
# Exercise 1.26 (Scott 1981, PRG-19, ┬π1) έΑΦ ideals of a commutative ring

Scott (for algebraists): let `A` be a commutative ring with unit and let `╬Φ` be the set of finite
subsets `F έΛΗ A`. Put

`I(F) = {G έΙΙ ╬Φ έΙμ F έΛΗ έθρGέθσ}` (the ideal generated by `G`).

Then the sets `I(F)` form a neighbourhood system and the corresponding domain is isomorphic to the
poset `(Ideals A, έΛΗ)`.

This file formalizes (`╬Φ = Finset A`, tokens are finite subsets):

* `IFamily F = {G έΙμ έΗΣF έΛΗ Ideal.span έΗΣG}` and `ringSystem`, the neighbourhood system. The master is
  `I(έΙΖ) = ╬Φ`, and `I(FέΓΒ) έΙσ I(FέΓΓ) = I(FέΓΒ έΙς FέΓΓ)` so the family is closed under **all** intersections
  (no consistency hypothesis needed έΑΦ `inter_mem` is unconditional).
* `idealOf x = {a έΙμ I({a}) έΙΙ x}` έΑΦ a filter's elements collapse to a genuine **ideal**; conversely
  `ofIdeal J = {I(F) έΙμ έΗΣF έΛΗ J}`.
* `ringIso : |ΏζΤθ| έΚΔo Ideal A` έΑΦ the order isomorphism to `(Ideals A, έΛΗ)` (Scott's claim). The token
  order is *reverse* (bigger `F` έθ╣ smaller `I(F)`), but the resulting filter order matches ideal
  inclusion.

Constructive (`[propext, Quot.sound]`): the round trips are equational, the only inputs being
mathlib's `Ideal.span` API. -/

namespace Scott1980.Neighborhood

namespace Ring

open NeighborhoodSystem

variable {A : Type*} [CommRing A]

/-- **Exercise 1.26 έΑΦ the basic neighbourhood `I(F)`.** `I(F) = {G έΙμ F έΛΗ έθρGέθσ}`, the finite sets `G`
whose generated ideal contains `F`. -/
def IFamily (F : Finset A) : Set (Finset A) := {G | (έΗΣF : Set A) έΛΗ Ideal.span (έΗΣG : Set A)}

@[simp] theorem mem_IFamily {F G : Finset A} :
    G έΙΙ IFamily F έΗΦ (έΗΣF : Set A) έΛΗ Ideal.span (έΗΣG : Set A) := Iff.rfl

/-- Inclusion of neighbourhoods reversed to ideal generation: `I(FέΓΒ) έΛΗ I(FέΓΓ) έΗΦ FέΓΓ έΛΗ έθρFέΓΒέθσ`. -/
theorem IFamily_subset_iff (FέΓΒ FέΓΓ : Finset A) :
    IFamily FέΓΒ έΛΗ IFamily FέΓΓ έΗΦ (έΗΣFέΓΓ : Set A) έΛΗ Ideal.span (έΗΣFέΓΒ : Set A) := by
  constructor
  ┬╖ intro h
    have hFέΓΒ : FέΓΒ έΙΙ IFamily FέΓΒ := mem_IFamily.mpr Ideal.subset_span
    exact (h hFέΓΒ)
  ┬╖ intro h G hG
    rw [mem_IFamily] at hG έΛλ
    exact h.trans (SetLike.coe_subset_coe.mpr (Ideal.span_le.mpr hG))

theorem span_eq_of_IFamily_eq {FέΓΒ FέΓΓ : Finset A} (h : IFamily FέΓΒ = IFamily FέΓΓ) :
    Ideal.span (έΗΣFέΓΒ : Set A) = Ideal.span (έΗΣFέΓΓ : Set A) := by
  have h12 : (έΗΣFέΓΓ : Set A) έΛΗ Ideal.span (έΗΣFέΓΒ : Set A) :=
    (IFamily_subset_iff FέΓΒ FέΓΓ).mp h.le
  have h21 : (έΗΣFέΓΒ : Set A) έΛΗ Ideal.span (έΗΣFέΓΓ : Set A) :=
    (IFamily_subset_iff FέΓΓ FέΓΒ).mp h.ge
  exact le_antisymm (Ideal.span_le.mpr h21) (Ideal.span_le.mpr h12)

theorem IFamily_eq_of_span_eq {FέΓΒ FέΓΓ : Finset A}
    (h : Ideal.span (έΗΣFέΓΒ : Set A) = Ideal.span (έΗΣFέΓΓ : Set A)) : IFamily FέΓΒ = IFamily FέΓΓ := by
  apply Set.Subset.antisymm
  ┬╖ exact (IFamily_subset_iff FέΓΒ FέΓΓ).mpr (by rw [h]; exact Ideal.subset_span)
  ┬╖ exact (IFamily_subset_iff FέΓΓ FέΓΒ).mpr (by rw [έΗΡ h]; exact Ideal.subset_span)

variable [DecidableEq A]

/-- `I(FέΓΒ) έΙσ I(FέΓΓ) = I(FέΓΒ έΙς FέΓΓ)`: the system is closed under all binary intersections. -/
theorem IFamily_inter (FέΓΒ FέΓΓ : Finset A) :
    IFamily FέΓΒ έΙσ IFamily FέΓΓ = IFamily (FέΓΒ έΙς FέΓΓ) := by
  ext G
  simp only [IFamily, Set.mem_inter_iff, Set.mem_setOf_eq, Finset.coe_union, Set.union_subset_iff]

/-- **Exercise 1.26 έΑΦ the neighbourhood system of a commutative ring.** Tokens are finite subsets
`F έΛΗ A`; neighbourhoods are the sets `I(F)`. The master is `I(έΙΖ)` (all of `╬Φ`), and intersections
`I(FέΓΒ) έΙσ I(FέΓΓ) = I(FέΓΒ έΙς FέΓΓ)` are always neighbourhoods. -/
def ringSystem : NeighborhoodSystem (Finset A) where
  mem S := έΙΔ F, S = IFamily F
  master := IFamily έΙΖ
  master_mem := έθρέΙΖ, rflέθσ
  inter_mem := by
    rintro X Y Z έθρFέΓΒ, rflέθσ έθρFέΓΓ, rflέθσ _ _
    exact έθρFέΓΒ έΙς FέΓΓ, IFamily_inter FέΓΒ FέΓΓέθσ
  sub_master := by
    rintro X έθρF, rflέθσ
    exact (IFamily_subset_iff F έΙΖ).mpr (by rw [Finset.coe_empty]; exact Set.empty_subset _)

@[simp] theorem ringSystem_mem {S : Set (Finset A)} :
    (ringSystem (A := A)).mem S έΗΦ έΙΔ F, S = IFamily F := Iff.rfl

theorem IFamily_mem (F : Finset A) : (ringSystem (A := A)).mem (IFamily F) := έθρF, rflέθσ

/-! ### From filters to ideals. -/

/-- **Exercise 1.26 έΑΦ the ideal of a filter.** `idealOf x = {a έΙμ I({a}) έΙΙ x}`. The closure
properties of an ideal come from the filter axioms: `0` from the master, `+` from `έΙσ`-closure
(`I({a}) έΙσ I({b}) = I({a,b}) έΛΗ I({a+b})`), and `έΑλ` from upward closure (`I({a}) έΛΗ I({c┬╖a})`). -/
def idealOf (x : (ringSystem (A := A)).Element) : Ideal A where
  carrier := {a | x.mem (IFamily {a})}
  zero_mem' := by
    show x.mem (IFamily {(0 : A)})
    refine x.up_mem x.master_mem (IFamily_mem {(0 : A)}) ?_
    intro G _
    rw [mem_IFamily, Finset.coe_singleton, Set.singleton_subset_iff]
    exact Submodule.zero_mem _
  add_mem' := by
    intro a b ha hb
    show x.mem (IFamily {a + b})
    have h := x.inter_mem ha hb
    rw [IFamily_inter] at h
    refine x.up_mem h (IFamily_mem {a + b}) ?_
    apply (IFamily_subset_iff _ _).mpr
    rw [Finset.coe_singleton, Set.singleton_subset_iff, Finset.coe_union,
      Finset.coe_singleton, Finset.coe_singleton]
    exact Ideal.add_mem _ (Ideal.subset_span (by simp)) (Ideal.subset_span (by simp))
  smul_mem' := by
    intro c a ha
    show x.mem (IFamily {c έΑλ a})
    refine x.up_mem ha (IFamily_mem {c έΑλ a}) ?_
    apply (IFamily_subset_iff _ _).mpr
    rw [Finset.coe_singleton, Set.singleton_subset_iff, Finset.coe_singleton]
    exact Submodule.smul_mem _ c (Ideal.subset_span (Set.mem_singleton a))

@[simp] theorem mem_idealOf {x : (ringSystem (A := A)).Element} {a : A} :
    a έΙΙ idealOf x έΗΦ x.mem (IFamily {a}) := Iff.rfl

/-- A filter contains `I(F)` whenever it contains `I({a})` for every `a έΙΙ F` (by `έΙσ`-closure). -/
theorem mem_IFamily_of_forall (x : (ringSystem (A := A)).Element) (F : Finset A)
    (h : έΙΑ a έΙΙ F, x.mem (IFamily {a})) : x.mem (IFamily F) := by
  classical
  induction F using Finset.induction with
  | empty => exact x.master_mem
  | @insert a F' _ ih =>
    have hins : (insert a F' : Finset A) = {a} έΙς F' := by
      ext y; simp [Finset.mem_insert]
    rw [hins, έΗΡ IFamily_inter]
    exact x.inter_mem (h a (by simp)) (ih (fun b hb => h b (by simp [hb])))

/-! ### From ideals to filters. -/

/-- **Exercise 1.26 έΑΦ the filter of an ideal.** `ofIdeal J = {I(F) έΙμ έΗΣF έΛΗ J}`. -/
def ofIdeal (J : Ideal A) : (ringSystem (A := A)).Element where
  mem S := έΙΔ F, S = IFamily F έΙπ Ideal.span (έΗΣF : Set A) έΚν J
  sub := by rintro S έθρF, rfl, _έθσ; exact έθρF, rflέθσ
  master_mem := by
    refine έθρέΙΖ, rfl, ?_έθσ
    rw [Finset.coe_empty, Ideal.span_empty]
    exact bot_le
  inter_mem := by
    rintro X Y έθρFέΓΒ, rfl, hέΓΒέθσ έθρFέΓΓ, rfl, hέΓΓέθσ
    refine έθρFέΓΒ έΙς FέΓΓ, IFamily_inter FέΓΒ FέΓΓ, ?_έθσ
    rw [Finset.coe_union, Ideal.span_union]
    exact sup_le hέΓΒ hέΓΓ
  up_mem := by
    rintro X Y έθρF, rfl, hFέθσ έθρF', rflέθσ hXY
    refine έθρF', rfl, ?_έθσ
    have hsub : (έΗΣF' : Set A) έΛΗ Ideal.span (έΗΣF : Set A) := (IFamily_subset_iff F F').mp hXY
    exact (Ideal.span_le.mpr hsub).trans hF

theorem mem_ofIdeal_IFamily (J : Ideal A) (F : Finset A) :
    (ofIdeal J).mem (IFamily F) έΗΦ Ideal.span (έΗΣF : Set A) έΚν J := by
  constructor
  ┬╖ rintro έθρF', hF', hleέθσ
    rw [span_eq_of_IFamily_eq hF']
    exact hle
  ┬╖ intro h
    exact έθρF, rfl, hέθσ

/-! ### The order isomorphism `|ΏζΤθ| έΚΖ (Ideals A, έΛΗ)`. -/

theorem idealOf_ofIdeal (J : Ideal A) : idealOf (ofIdeal J) = J := by
  apply SetLike.ext
  intro a
  rw [mem_idealOf, mem_ofIdeal_IFamily, Finset.coe_singleton, Ideal.span_singleton_le_iff_mem]

theorem ofIdeal_idealOf (x : (ringSystem (A := A)).Element) : ofIdeal (idealOf x) = x := by
  apply NeighborhoodSystem.Element.ext
  intro S
  constructor
  ┬╖ rintro έθρF, rfl, hFέθσ
    refine mem_IFamily_of_forall x F (fun a ha => ?_)
    have haspan : a έΙΙ Ideal.span (έΗΣF : Set A) := Ideal.subset_span (by simpa using ha)
    exact mem_idealOf.mp (hF haspan)
  ┬╖ intro hS
    obtain έθρF, rflέθσ := x.sub hS
    refine έθρF, rfl, ?_έθσ
    rw [Ideal.span_le]
    intro a ha
    rw [SetLike.mem_coe, mem_idealOf]
    refine x.up_mem hS (IFamily_mem {a}) ?_
    apply (IFamily_subset_iff _ _).mpr
    rw [Finset.coe_singleton, Set.singleton_subset_iff]
    exact Ideal.subset_span ha

/-- **Exercise 1.26 έΑΦ `|ΏζΤθ| έΚΖ (Ideals A, έΛΗ)`.** The domain of the ring's neighbourhood system is
order-isomorphic to the ideals of `A` ordered by inclusion, via `x έΗο {a έΙμ I({a}) έΙΙ x}`. -/
def ringIso : (ringSystem (A := A)).Element έΚΔo Ideal A where
  toFun := idealOf
  invFun := ofIdeal
  left_inv := ofIdeal_idealOf
  right_inv := idealOf_ofIdeal
  map_rel_iff' := by
    intro x y
    constructor
    ┬╖ intro h S hS
      obtain έθρF, rflέθσ := x.sub hS
      refine mem_IFamily_of_forall y F (fun a ha => ?_)
      have hax : a έΙΙ idealOf x := by
        rw [mem_idealOf]
        exact x.up_mem hS (IFamily_mem {a}) <| (IFamily_subset_iff _ _).mpr <| by
          rw [Finset.coe_singleton, Set.singleton_subset_iff]
          exact Ideal.subset_span (by simpa using ha)
      exact mem_idealOf.mp (h hax)
    ┬╖ intro h a ha
      exact h (IFamily {a}) ha

end Ring

end Scott1980.Neighborhood
