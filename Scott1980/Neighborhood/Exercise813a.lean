import Scott1980.Neighborhood.Exercise812
import Scott1980.Neighborhood.Exercise812g4

/-!
# Exercise 8.13(a) (Scott 1981, PRG-19, Lecture VIII) — `V` *is* the free Boolean algebra on `ℵ₀`
generators

Exercise 8.13's "(for logicians)" half asks to show `U` is isomorphic to the domain of all proper
filters of the free Boolean algebra on `ℵ₀` generators. The key finding (see `arxiv.md`'s `8.13`
scoping row) is that `Exercise812.lean`'s `V` — `levelSet k m = {n | m.testBit (n % 2^k)}`, already
known `≅ᴰ U` (`Exercise812g4.lean`) — *already is* this algebra, concretely realized via the bits
of `n : ℕ`. This file makes that identification precise and complete:

* `generator i := {n | n.testBit i}`, the `ℵ₀` generators (independent propositional variables).
* `GeneratedBy generator` — the Boolean subalgebra of `Set ℕ` they generate.
* `V_mem_iff_generatedBy` — **`V.mem X ↔ GeneratedBy generator X ∧ X.Nonempty`**: `V`'s
  neighbourhoods are *exactly* the (non-empty) elements of this algebra. Since `V.Element`'s
  defining filter conditions (`Basic.lean`'s `Element` — upward closed, finite-meet-closed,
  contains the top, and (via `V.mem` excluding `∅`) never contains the bottom) are precisely "proper
  filter of `{X | GeneratedBy generator X}`", this makes `V.Element` *by definition* the domain of
  proper filters of the algebra generated by `generator`.
* `generators_independent` — the `generator i` are independent (every finite Boolean combination is
  non-empty), the standard combinatorial property characterizing "generates a *free* Boolean
  algebra" (a citation, not a re-derivation, of the universal-algebra fact that a countable Boolean
  algebra with countably many independent generators is the free Boolean algebra on `ℵ₀` generators
  — `= the Lindenbaum algebra of propositional calculus` per `8.13`'s own gloss, see `8.13(b)` for
  the optional literal formula-syntax bridge).
* `exercise813a` — the headline: `U ≅ᴰ V`, hence effectively `U` is isomorphic to the domain of
  proper filters of the free Boolean algebra on `ℵ₀` generators, via `effectiveIso812_UV` (already
  `Pass`, `Exercise812g4.lean`). No new back-and-forth argument is needed at all.
-/

namespace Scott1980.Neighborhood

open NeighborhoodSystem

/-! ### A general bit-arithmetic toolkit (not specific to `generator`) -/

/-- **`n % 2^k`'s bit `i`** is `n`'s own bit `i` when `i < k` (the low bits are preserved by
reduction mod `2^k`), and `false` otherwise (nothing above bit `k-1` survives). Proved via the
division algorithm (`Nat.div_add_mod`) fed into `Nat.testBit_two_pow_mul_add`. -/
theorem testBit_mod_two_pow (n k i : ℕ) :
    (n % 2 ^ k).testBit i = (decide (i < k) && n.testBit i) := by
  have hlt : n % 2 ^ k < 2 ^ k := Nat.mod_lt n (Nat.two_pow_pos k)
  have h := Nat.testBit_two_pow_mul_add (n / 2 ^ k) hlt i
  rw [Nat.div_add_mod] at h
  rcases Nat.lt_or_ge i k with hik | hik
  · simp only [hik, if_true, decide_true, Bool.true_and] at h ⊢
    exact h.symm
  · simp only [Nat.not_lt.mpr hik, decide_false, Bool.false_and]
    exact Nat.testBit_eq_false_of_lt (hlt.trans_le (Nat.pow_le_pow_right (by norm_num) hik))

/-- Specialization of `testBit_mod_two_pow` used repeatedly below: reducing mod `2^(i+1)` never
disturbs bit `i` itself. -/
theorem testBit_mod_two_pow_succ (n i : ℕ) :
    (n % 2 ^ (i + 1)).testBit i = n.testBit i := by
  rw [testBit_mod_two_pow]; simp

/-- **`(∑ j ∈ s, 2^j).testBit i ↔ i ∈ s`.** The general "read off a prescribed finite bit pattern"
fact behind `upsample` (`Exercise812.lean`) — isolated here for reuse. -/
theorem testBit_sum_two_pow {s : Finset ℕ} {i : ℕ} : (∑ j ∈ s, 2 ^ j).testBit i ↔ i ∈ s := by
  rw [← Nat.mem_bitIndices, ← List.mem_toFinset, Finset.toFinset_bitIndices_sum_two_pow]

/-- Build a natural number with a prescribed (finite) set of bits set — the "witness" constructor
used both for `generator`'s `levelSet` realization and for the complement/independence proofs
below. -/
def bitmaskOf (s : Finset ℕ) : ℕ := ∑ j ∈ s, 2 ^ j

@[simp] theorem testBit_bitmaskOf {s : Finset ℕ} {i : ℕ} : (bitmaskOf s).testBit i ↔ i ∈ s :=
  testBit_sum_two_pow

/-! ### `generator i`: the `i`-th independent propositional variable, as a subset of `ℕ` -/

/-- The **`i`-th generator**: `{n | n.testBit i}`, the set of naturals whose `i`-th binary digit is
`1`. These are Scott's `ℵ₀` propositional variables, realized concretely. -/
def generator (i : ℕ) : Set ℕ := {n : ℕ | n.testBit i = true}

@[simp] theorem mem_generator {i n : ℕ} : n ∈ generator i ↔ n.testBit i = true := Iff.rfl

theorem generator_nonempty (i : ℕ) : (generator i).Nonempty := ⟨2 ^ i, by simp⟩

/-- Every `generator i` is a `V`-neighbourhood: `generator i = levelSet (i+1) M` for the bitmask
`M` selecting exactly the residues `< 2^(i+1)` whose own bit `i` is set. -/
theorem generator_eq_levelSet (i : ℕ) :
    generator i = levelSet (i + 1) (bitmaskOf ((Finset.range (2 ^ (i + 1))).filter
      (fun ℓ => ℓ.testBit i))) := by
  ext n
  simp only [mem_generator, mem_levelSet, testBit_bitmaskOf, Finset.mem_filter, Finset.mem_range]
  rw [← testBit_mod_two_pow_succ]
  exact ⟨fun h => ⟨Nat.mod_lt n (Nat.two_pow_pos _), h⟩, fun h => h.2⟩

theorem V_mem_generator (i : ℕ) : V.mem (generator i) :=
  generator_eq_levelSet i ▸ ⟨i + 1, _, rfl, generator_eq_levelSet i ▸ generator_nonempty i⟩

/-! ### `levelSet` is closed under complement, unconditionally (up to `∅`) -/

/-- **`levelSet` is closed under complement** (within the "`∅`-or-genuine" dichotomy every closure
fact in this development uses): the bitmask that selects exactly the residues `< 2^k` *not*
selected by `m`. -/
theorem levelSet_compl (k m : ℕ) :
    (levelSet k m)ᶜ = levelSet k (bitmaskOf ((Finset.range (2 ^ k)).filter
      (fun ℓ => ¬ m.testBit ℓ))) := by
  ext n
  simp only [Set.mem_compl_iff, mem_levelSet, testBit_bitmaskOf, Finset.mem_filter,
    Finset.mem_range]
  exact ⟨fun h => ⟨Nat.mod_lt n (Nat.two_pow_pos _), h⟩, fun h => h.2⟩

theorem V_compl_mem {X : Set ℕ} (hX : V.mem X) : Xᶜ = ∅ ∨ V.mem Xᶜ := by
  obtain ⟨k, m, rfl, -⟩ := hX
  rw [levelSet_compl]
  rcases (levelSet _ _).eq_empty_or_nonempty with h | h
  · exact Or.inl h
  · exact Or.inr ⟨k, _, rfl, h⟩

/-! ### The Boolean algebra generated by `generator`, and its identification with `V.mem` -/

/-- The Boolean subalgebra of `Set ℕ` generated by a family `g` of "generators": the smallest
family containing every `g i` and `Set.univ`, closed under `∩`, `∪`, and complement. (`∅` is
derivable: `univ.compl`.) -/
inductive GeneratedBy {α : Type*} (g : ℕ → Set α) : Set α → Prop
  | of (i : ℕ) : GeneratedBy g (g i)
  | univ : GeneratedBy g Set.univ
  | inter {X Y} : GeneratedBy g X → GeneratedBy g Y → GeneratedBy g (X ∩ Y)
  | union {X Y} : GeneratedBy g X → GeneratedBy g Y → GeneratedBy g (X ∪ Y)
  | compl {X} : GeneratedBy g X → GeneratedBy g Xᶜ

/-- **Soundness**: everything generated by `generator` is either empty or a genuine
`V`-neighbourhood. -/
theorem generatedBy_generator_imp {X : Set ℕ} (h : GeneratedBy generator X) :
    X = ∅ ∨ V.mem X := by
  induction h with
  | of i => exact Or.inr (V_mem_generator i)
  | univ => exact Or.inr V.master_mem
  | @inter X Y _ _ ih1 ih2 =>
    rcases ih1 with rfl | hX
    · exact Or.inl (Set.empty_inter Y)
    rcases ih2 with rfl | hY
    · exact Or.inl (Set.inter_empty X)
    obtain ⟨k₁, m₁, rfl, -⟩ := hX
    obtain ⟨k₂, m₂, rfl, -⟩ := hY
    rw [levelSet_inter]
    rcases (levelSet _ _).eq_empty_or_nonempty with h | h
    · exact Or.inl h
    · exact Or.inr ⟨_, _, rfl, h⟩
  | union _ _ ih1 ih2 => exact V_union_mem ih1 ih2
  | @compl X _ ih =>
    rcases ih with rfl | hX
    · simp only [Set.compl_empty]
      exact Or.inr V.master_mem
    · exact V_compl_mem hX

/-- **Completeness**: every `V`-neighbourhood is generated by `generator`. `affine k ℓ` (a single
residue class) is a finite intersection of generators/their complements (one constraint per bit
`i < k`); `levelSet k m` is a finite union of those over the residues `ℓ` selected by `m`
(`levelSet_eq_biUnion`), assembled by `Finset` induction using `GeneratedBy.union`. -/
theorem affine_eq_biInter (k ℓ : ℕ) (hℓ : ℓ < 2 ^ k) :
    affine k ℓ = ⋂ i ∈ Finset.range k, (if ℓ.testBit i then generator i else (generator i)ᶜ) := by
  ext n
  simp only [mem_affine, Set.mem_iInter, Finset.mem_range]
  have key : n % 2 ^ k = ℓ ↔ ∀ i < k, n.testBit i = ℓ.testBit i := by
    constructor
    · rintro rfl i hi
      rw [testBit_mod_two_pow]; simp [hi]
    · intro h
      apply Nat.eq_of_testBit_eq
      intro i
      rw [testBit_mod_two_pow]
      rcases Nat.lt_or_ge i k with hik | hik
      · simp [hik, h i hik]
      · simp only [Nat.not_lt.mpr hik, decide_false, Bool.false_and]
        exact (Nat.testBit_eq_false_of_lt (hℓ.trans_le (Nat.pow_le_pow_right (by norm_num) hik))).symm
  rw [key]
  refine forall₂_congr fun i _ => ?_
  split_ifs with hb <;> simp [hb]

theorem generatedBy_affine (k ℓ : ℕ) (hℓ : ℓ < 2 ^ k) : GeneratedBy generator (affine k ℓ) := by
  rw [affine_eq_biInter k ℓ hℓ]
  induction Finset.range k using Finset.induction_on with
  | empty => simpa using GeneratedBy.univ
  | insert a s _ ih =>
    rw [Finset.set_biInter_insert]
    refine GeneratedBy.inter ?_ ih
    split_ifs with hb
    · exact GeneratedBy.of _
    · exact GeneratedBy.compl (GeneratedBy.of _)

theorem generatedBy_biUnion_affine (k : ℕ) (s : Finset ℕ) (hs : ∀ ℓ ∈ s, ℓ < 2 ^ k) :
    GeneratedBy generator (⋃ ℓ ∈ s, affine k ℓ) := by
  induction s using Finset.induction_on with
  | empty => simpa using GeneratedBy.univ.compl
  | insert a s ha ih =>
    rw [Finset.set_biUnion_insert]
    exact GeneratedBy.union (generatedBy_affine k a (hs a (Finset.mem_insert_self a s)))
      (ih fun ℓ hℓ => hs ℓ (Finset.mem_insert_of_mem hℓ))

theorem generatedBy_levelSet (k m : ℕ) : GeneratedBy generator (levelSet k m) := by
  rw [levelSet_eq_biUnion]
  exact generatedBy_biUnion_affine k _ fun ℓ hℓ => (Finset.mem_filter.mp hℓ).1 |> Finset.mem_range.mp

/-- **`V.mem` is *exactly* "non-empty and generated by `generator`"** — soundness
(`generatedBy_generator_imp`) plus completeness (`generatedBy_levelSet`). Since `V.Element`'s
defining conditions (`Basic.lean`'s `Element`: upward-closed, finite-meet-closed, contains the
top, and — because `V.mem` excludes `∅` — never contains the bottom) are precisely "proper filter
of `{X | GeneratedBy generator X}`", this makes **`V.Element` *by definition* the domain of proper
filters of the Boolean algebra generated by `generator`**. -/
theorem V_mem_iff_generatedBy {X : Set ℕ} : V.mem X ↔ GeneratedBy generator X ∧ X.Nonempty := by
  constructor
  · rintro ⟨k, m, rfl, hne⟩
    exact ⟨generatedBy_levelSet k m, hne⟩
  · rintro ⟨hgen, hne⟩
    exact (generatedBy_generator_imp hgen).resolve_left hne.ne_empty

/-! ### `generator`'s independence: the algebra is *free* on `ℵ₀` generators -/

/-- **The `generator i` are independent**: every finite Boolean combination — assign each `i ∈ s`
to `generator i` (if `ε i`) or its complement (otherwise) — is non-empty. This is the standard
combinatorial characterization of "freely generates a Boolean algebra": no relation among finitely
many generators is forced beyond what Boolean algebra alone requires. Combined with
`V_mem_iff_generatedBy`, this identifies the algebra generated by `generator` as *the* free Boolean
algebra on `ℵ₀` generators (= the Lindenbaum algebra of propositional calculus, `8.13`'s own gloss
— a standard citation, see `8.13(b)` for the optional literal syntactic bridge). -/
theorem generators_independent (s : Finset ℕ) (ε : ℕ → Bool) :
    (⋂ i ∈ s, if ε i then generator i else (generator i)ᶜ).Nonempty := by
  refine ⟨bitmaskOf (s.filter (fun i => ε i)), ?_⟩
  simp only [Set.mem_iInter]
  intro i hi
  split_ifs with hb <;> simp [testBit_bitmaskOf, Finset.mem_filter, hi, hb]

/-! ### Headline: Exercise 8.13's "(for logicians)" half -/

/-- **Exercise 8.13(a).** `U` is isomorphic to `V`'s domain of elements, and `V`'s domain of
elements is (`V_mem_iff_generatedBy`, `generators_independent`) *by construction* the domain of
proper filters of the free Boolean algebra on `ℵ₀` generators. No new back-and-forth argument is
needed: `effectiveIso812_UV` (`Exercise812g4.lean`, already `Pass`) already supplies the
isomorphism (in fact an *effective* one, stronger than what `8.13` asks for). -/
theorem exercise813a : U ≅ᴰ V := ⟨effectiveIso812_UV.toDomainIso⟩

end Scott1980.Neighborhood
