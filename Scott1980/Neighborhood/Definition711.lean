import Scott1980.Neighborhood.Proposition710
import Mathlib.Tactic

/-!
# Definition 7.11 (Scott 1981, PRG-19, ┬з7) тАФ finite-element joins in `тДЩЁЭТЯ`

Scott introduces the power-domain analogue of a *finite set* of elements.

**Definition 7.11.** For elements `xтВА, тАж, x_{n-1} тИИ |ЁЭТЯ|` define

`{xтВА, тАж, x_{n-1}} = { z тИИ |тДЩЁЭТЯ| тИг тИГ XтВА тИИ xтВА тАж тИГ X_{n-1} тИИ x_{n-1}.
  тЛГ_{i<n} (тЖСX_i) тКЖ z }`,

where `тЖСX` is the principal filter of `X тИИ ЁЭТЯ`. Scott also notes the equivalent formulation
`тИА i < n. X_i тИИ z` (read with `X_i` identified with the down-set `тЖУX_i тИИ тДЩЁЭТЯ`).

On finite elements `тЖСX` of `|ЁЭТЯ|`, `{тЖСX}` is the principal filter `тЖС(тЖУX)` of `тДЩЁЭТЯ` (Prop 7.12).

## What this file formalizes

Building on `Proposition710.lean`'s `PowerDomain`, we package Scott's join as a filter
`PDfinJoin xs : V.PowerDomain.Element` for `xs : Fin n тЖТ V.Element` (`n = 0` gives `тКе`).

Membership is the down-set form of Scott's union condition:

`W тИИ {xтВА,тАж,x_{n-1}} тЖФ тИГ (X_i тИИ x_i). PD.mem W тИз тИА i. тЖУX_i тКЖ W`,

equivalently `PD.mem W тИз тЛГ_{i<n} тЖУX_i тКЖ W` for some choice of representatives. The singleton
`PDsingleton x` is the unary join; on principal filters, `PDsingleton (тЖСX) = тЖС(тЖУX)`.
-/

namespace Scott1980.Neighborhood

namespace NeighborhoodSystem

variable {╬▒ : Type*} (V : NeighborhoodSystem ╬▒)

/-! ### Definition 7.11 тАФ membership predicate. -/

/-- **Definition 7.11 тАФ membership.** A `тДЩЁЭТЯ`-neighbourhood `W` lies in the join of
`xтВА, тАж, x_{n-1}` iff some choice of representatives `X_i тИИ x_i` has every down-set
`тЖУX_i` contained in `W` (Scott's `тЛГ_{i<n} (тЖСX_i) тКЖ z`, read as down-sets in `тДЩЁЭТЯ`). -/
def PDmemFinJoin {n : тДХ} (xs : Fin n тЖТ V.Element) (W : Set (Set ╬▒)) : Prop :=
  тИГ (X : Fin n тЖТ Set ╬▒) (hX : тИА i, (xs i).mem (X i)),
    V.PowerDomain.mem W тИз тИА i, V.upSet (X i) тКЖ W

/-! ### Definition 7.11 тАФ the join element. -/

/-- **Definition 7.11 тАФ the empty join.** With no arguments, `{ } = тКе` (the least element of
`|тДЩЁЭТЯ|`). -/
def PDfinJoinZero : V.PowerDomain.Element := V.PowerDomain.bot

/-- **Definition 7.11 тАФ the non-empty join.** For `n тЙе 1`, `{xтВА,тАж,x_{n-1}}` is the filter
generated by Scott's union condition. -/
def PDfinJoinSucc {m : тДХ} (xs : Fin (m + 1) тЖТ V.Element) : V.PowerDomain.Element where
  mem := V.PDmemFinJoin xs
  sub hW := by obtain тЯи_, _, hPD, _тЯй := hW; exact hPD
  master_mem := by
    refine тЯиfun i => V.master, fun i => (xs i).master_mem, V.PDmem_master, fun i Z hz => hzтЯй
  inter_mem h1 h2 := by
    obtain тЯиX1, hX1, hPD1, hsub1тЯй := h1
    obtain тЯиX2, hX2, hPD2, hsub2тЯй := h2
    refine тЯиfun i => X1 i тИй X2 i, fun i => (xs i).inter_mem (hX1 i) (hX2 i),
      V.PDmem_inter hPD1 hPD2, fun i Y hY => ?_тЯй
    rw [тЖР V.upSet_inter] at hY
    rcases hY with тЯиhY1, hY2тЯй
    exact тЯиhsub1 i hY1, hsub2 i hY2тЯй
  up_mem h hW hsub := by
    obtain тЯиX, hX, _, hsub'тЯй := h
    exact тЯиX, hX, hW, fun i => (hsub' i).trans hsubтЯй

/-- **Definition 7.11.** The finite-element join `{xтВА,тАж,x_{n-1}}` in `|тДЩЁЭТЯ|`. The empty
family yields `тКе`; otherwise use Scott's union-of-down-sets condition. -/
def PDfinJoin (n : тДХ) (xs : Fin n тЖТ V.Element) : V.PowerDomain.Element :=
  match n with
  | 0 => V.PDfinJoinZero
  | m + 1 => V.PDfinJoinSucc xs

@[simp] theorem PDmem_finJoinZero {W : Set (Set ╬▒)} :
    (V.PDfinJoinZero).mem W тЖФ W = V.PowerDomain.master := by
  rw [PDfinJoinZero, mem_bot, PowerDomain_master]

theorem PDmem_finJoinSucc {m : тДХ} (xs : Fin (m + 1) тЖТ V.Element) {W : Set (Set ╬▒)} :
    (V.PDfinJoinSucc xs).mem W тЖФ V.PDmemFinJoin xs W := Iff.rfl

theorem PDmem_finJoin {n : тДХ} (xs : Fin n тЖТ V.Element) {W : Set (Set ╬▒)} :
    (V.PDfinJoin n xs).mem W тЖФ
      if n = 0 then W = V.PowerDomain.master else V.PDmemFinJoin xs W := by
  match n with
  | 0 => simp [PDfinJoin, PDfinJoinZero, mem_bot, PowerDomain_master]
  | m + 1 => simp [PDfinJoin, PDfinJoinSucc, PDmem_finJoinSucc]

/-- **Definition 7.11 тАФ Scott's displayed union form.** For `n тЙе 1`, membership is equivalent to
some representatives `X_i тИИ x_i` with `тЛГ_{i<n} тЖУX_i тКЖ W`. -/
theorem PDmem_finJoin_iUnion {m : тДХ} (xs : Fin (m + 1) тЖТ V.Element) {W : Set (Set ╬▒)} :
    (V.PDfinJoinSucc xs).mem W тЖФ
      тИГ (X : Fin (m + 1) тЖТ Set ╬▒) (hX : тИА i, (xs i).mem (X i)),
        V.PowerDomain.mem W тИз
          (тЛГ i, V.upSet (X i)) тКЖ W := by
  rw [PDmem_finJoinSucc]
  constructor
  ┬╖ rintro тЯиX, hX, hPD, hsubтЯй
    exact тЯиX, hX, hPD, Set.iUnion_subset hsubтЯй
  ┬╖ rintro тЯиX, hX, hPD, hsubтЯй
    exact тЯиX, hX, hPD, (Set.iUnion_subset_iff).mp hsubтЯй

/-- **Definition 7.11 тАФ singleton join.** Write `{x}` for the unary join. -/
def PDsingleton (x : V.Element) : V.PowerDomain.Element := V.PDfinJoin 1 (fun (_ : Fin 1) => x)

@[simp] theorem PDmem_singleton {x : V.Element} {W : Set (Set ╬▒)} :
    (V.PDsingleton x).mem W тЖФ
      тИГ X, x.mem X тИз V.PowerDomain.mem W тИз V.upSet X тКЖ W := by
  rw [PDsingleton, PDfinJoin, PDmem_finJoinSucc, PDmemFinJoin]
  constructor
  ┬╖ rintro тЯиX, hX, hPD, hsubтЯй
    exact тЯиX 0, hX 0, hPD, hsub 0тЯй
  ┬╖ rintro тЯиX, hX, hPD, hsubтЯй
    refine тЯиfun _ => X, fun _ => hX, hPD, fun _ => hsubтЯй

end NeighborhoodSystem

end Scott1980.Neighborhood
